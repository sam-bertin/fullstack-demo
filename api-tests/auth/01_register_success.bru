meta {
  name: Register user success or already exists
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{authEmail}}",
    "username": "{{authUsername}}",
    "password": "{{authPass}}"
  }
}

tests {
  test("status is 201 (new user) or 409 (already exists)", function() {
    const status = res.getStatus();
    expect([201, 409]).to.include(status);
  });

  test("201 returns success=true", function() {
    if (res.getStatus() === 201) {
      expect(res.body.success).to.equal(true);
      expect(res.body.data.email).to.contain("@");
    }
  });

  test("409 returns RESOURCE_CONFLICT", function() {
    if (res.getStatus() === 409) {
      expect(res.body.success).to.equal(false);
      expect(res.body.errorCode).to.equal("RESOURCE_CONFLICT");
    }
  });
}