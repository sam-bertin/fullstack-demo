meta {
  name: Login success
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{authEmail}}",
    "password": "{{authPass}}"
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("returns success and temporary auth mode", function() {
    expect(res.body.success).to.equal(true);
    expect(res.body.data.user.email).to.contain("@");
    expect(res.body.data.authMode).to.equal("PASSWORD_ONLY_TEMPORARY");
  });
}